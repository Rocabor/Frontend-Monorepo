{
  "name": "turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "portal": "vite",               
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "Get-ChildItem -Path '.' -Include 'node_modules' -Recurse -Directory | Remove-Item -Recurse -Force; pnpm store prune; pnpm install"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.9.6",
    "typescript": "5.9.2",
    "vite": "^8.0.8"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "vue": "^3.5.33"
  }
}