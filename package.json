{
  "name": "turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build && pnpm portal:build && node ./scripts/unify.mjs",
    "portal:build": "vite build",
    "portal:dev": "vite",
    "dev": "turbo run dev",
    "dev:all": "pnpm build && npx vite preview --port 4173",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "Get-ChildItem -Path '.' -Include 'node_modules' -Recurse -Directory | Remove-Item -Recurse -Force; pnpm store prune; pnpm install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "fs-extra": "^11.3.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.9.18",
    "typescript": "6.0.3",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "vue": "^3.5.38"
  }
}
