{
  "name": "turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build && pnpm portal:build && node ./scripts/unify.mjs",
    "portal:build": "vite build",
    "portal:dev": "vite",
    "dev": "turbo run dev",
    "dev:all": "pnpm build && npx vite preview --port 4173",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "Get-ChildItem -Path '.' -Include 'node_modules' -Recurse -Directory | Remove-Item -Recurse -Force; pnpm store prune; pnpm install"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "fs-extra": "^11.3.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.9.7",
    "typescript": "5.9.2",
    "vite": "^8.0.8"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "vue": "^3.5.33"
  }
}
